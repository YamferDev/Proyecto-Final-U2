<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.sysdenuncias.controller.MainGuiController" prefHeight="600.0" prefWidth="900.0">
    <top>
        <MenuBar>
            <menus>
                <Menu text="Mantenimiento">
                    <items>
                        <MenuItem fx:id="miCiudadanos" text="Ciudadanos" onAction="#menuAction"/>
                        <MenuItem fx:id="miFuncionarios" text="Funcionarios" onAction="#menuAction"/>
                        <MenuItem fx:id="miTiposDenuncia" text="Tipos de Denuncia" onAction="#menuAction"/>
                    </items>
                </Menu>
                <Menu text="Operaciones">
                    <items>
                        <MenuItem fx:id="miDenuncias" text="Gestión de Denuncias" onAction="#menuAction"/>
                    </items>
                </Menu>
                <Menu text="Sistema">
                    <items>
                        <MenuItem fx:id="miSalir" text="Salir" onAction="#menuAction"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <center>
        <TabPane fx:id="tabPaneFx" tabClosingPolicy="ALL_TABS" />
    </center>
</BorderPane>
